        <script>var dbConn = DatabaseConnectionFactory.createDatabaseConnection(
    &apos;org.postgresql.Driver&apos;,
    &apos;jdbc:postgresql://${DB_HOST}:${DB_PORT}/bridgelink_db&apos;,
    &apos;${DB_USERNAME}&apos;,
    &apos;${DB_PASSWORD}&apos;
);

var patientId = sourceMap.get(&apos;parameters&apos;) ? sourceMap.get(&apos;parameters&apos;).getParameter(&apos;patient_id&apos;) : null;
var query;
if (patientId == null || patientId == &apos;&apos;) {
    query = &quot;SELECT * FROM patients ORDER BY last_updated DESC LIMIT 50&quot;;
} else {
    query = &quot;SELECT * FROM patients WHERE patient_id = &apos;&quot; + patientId + &quot;&apos;&quot;;
}

var result = dbConn.executeCachedQuery(query);
var patients = [];

while (result.next()) {
    var patient = {
        &quot;resourceType&quot;: &quot;Patient&quot;,
        &quot;id&quot;: result.getString(&quot;patient_id&quot;),
        &quot;name&quot;: [
            {
                &quot;use&quot;: &quot;official&quot;,
                &quot;family&quot;: result.getString(&quot;last_name&quot;),
                &quot;given&quot;: [result.getString(&quot;first_name&quot;)]
            }
        ],
        &quot;gender&quot;: result.getString(&quot;gender&quot;) == &apos;M&apos; ? &apos;male&apos; : result.getString(&quot;gender&quot;) == &apos;F&apos; ? &apos;female&apos; : &apos;unknown&apos;,
        &quot;birthDate&quot;: result.getString(&quot;dob&quot;)
    };

    var status = result.getString(&quot;admission_status&quot;);
    if (status &amp;&amp; status !== &apos;UNKNOWN&apos;) {
        patient.extension = [
            {
                &quot;url&quot;: &quot;http://example.org/fhir/StructureDefinition/admission-status&quot;,
                &quot;valueString&quot;: status
            }
        ];
    }

    patients.push(patient);
}
dbConn.close();

var bundle = {
    &quot;resourceType&quot;: &quot;Bundle&quot;,
    &quot;type&quot;: &quot;searchset&quot;,
    &quot;total&quot;: patients.length,
    &quot;entry&quot;: patients.map(function(pat) {
        return { &quot;resource&quot;: pat };
    })
};

var responseContent = JSON.stringify(bundle, null, 2);
responseMap.put(&apos;response&apos;, responseContent);
return responseContent;</script>
