        <query>INSERT INTO patients (patient_id, first_name, last_name, dob, gender, admission_status, attending_physician, admit_date, last_updated)
VALUES (${patient_id}, ${first_name}, ${last_name}, TO_DATE(${dob}, &apos;YYYYMMDD&apos;), ${gender}, ${admission_status}, ${attending_physician}, TO_TIMESTAMP(${admit_date}, &apos;YYYYMMDDHH24MISS&apos;), NOW())
ON CONFLICT (patient_id) DO UPDATE SET
    first_name = ${first_name},
    last_name = ${last_name},
    dob = TO_DATE(${dob}, &apos;YYYYMMDD&apos;),
    gender = ${gender},
    admission_status = ${admission_status},
    attending_physician = ${attending_physician},
    admit_date = CASE WHEN ${admission_status} = &apos;ADMITTED&apos; THEN TO_TIMESTAMP(${admit_date}, &apos;YYYYMMDDHH24MISS&apos;) ELSE patients.admit_date END,
    discharge_date = CASE WHEN ${admission_status} = &apos;DISCHARGED&apos; THEN NOW() ELSE patients.discharge_date END,
    last_updated = NOW()</query>
