            <script>var dbConn = DatabaseConnectionFactory.createDatabaseConnection(
    &apos;org.postgresql.Driver&apos;,
    &apos;jdbc:postgresql://localhost:5433/mirthdb&apos;,
    &apos;postgres&apos;,
    &apos;postgres&apos;
);

var patientId = sourceMap.get(&apos;parameters&apos;) ? sourceMap.get(&apos;parameters&apos;).getParameter(&apos;patient_id&apos;) : null;
var query;
if (patientId == null || patientId == &apos;&apos;) {
    query = &quot;SELECT * FROM lab_results ORDER BY received_at DESC LIMIT 50&quot;;
} else {
    query = &quot;SELECT * FROM lab_results WHERE patient_id = &apos;&quot; + patientId + &quot;&apos; ORDER BY received_at DESC&quot;;
}

// LOINC code lookup
var loincMap = {
    &quot;Glucose&quot;: {&quot;code&quot;: &quot;2345-7&quot;, &quot;display&quot;: &quot;Glucose [Mass/volume] in Serum or Plasma&quot;},
    &quot;Potassium&quot;: {&quot;code&quot;: &quot;2823-3&quot;, &quot;display&quot;: &quot;Potassium [Moles/volume] in Serum or Plasma&quot;},
    &quot;White Blood Cell Count&quot;: {&quot;code&quot;: &quot;6690-2&quot;, &quot;display&quot;: &quot;Leukocytes [#/volume] in Blood&quot;},
    &quot;Hemoglobin&quot;: {&quot;code&quot;: &quot;718-7&quot;, &quot;display&quot;: &quot;Hemoglobin [Mass/volume] in Blood&quot;},
    &quot;Creatinine&quot;: {&quot;code&quot;: &quot;2160-0&quot;, &quot;display&quot;: &quot;Creatinine [Mass/volume] in Serum or Plasma&quot;}
};

var result = dbConn.executeCachedQuery(query);
var observations = [];

while (result.next()) {
    var testName = result.getString(&quot;test_name&quot;);
    var loinc = loincMap[testName] || {&quot;code&quot;: &quot;UNKNOWN&quot;, &quot;display&quot;: testName};

    var observation = {
        &quot;resourceType&quot;: &quot;Observation&quot;,
        &quot;id&quot;: result.getString(&quot;id&quot;),
        &quot;status&quot;: &quot;final&quot;,
        &quot;code&quot;: {
            &quot;coding&quot;: [
                {
                    &quot;system&quot;: &quot;http://loinc.org&quot;,
                    &quot;code&quot;: loinc.code,
                    &quot;display&quot;: loinc.display
                }
            ],
            &quot;text&quot;: testName
        },
        &quot;subject&quot;: {
            &quot;reference&quot;: &quot;Patient/&quot; + result.getString(&quot;patient_id&quot;),
            &quot;display&quot;: result.getString(&quot;patient_name&quot;)
        },
        &quot;valueQuantity&quot;: {
            &quot;value&quot;: parseFloat(result.getString(&quot;result_value&quot;)),
            &quot;unit&quot;: result.getString(&quot;units&quot;),
            &quot;system&quot;: &quot;http://unitsofmeasure.org&quot;
        },
        &quot;interpretation&quot;: [
            {
                &quot;coding&quot;: [
                    {
                        &quot;system&quot;: &quot;http://terminology.hl7.org/CodeSystem/v3-ObservationInterpretation&quot;,
                        &quot;code&quot;: result.getString(&quot;abnormal_flag&quot;) || &quot;N&quot;
                    }
                ]
            }
        ]
    };

    // Add ordering provider if available
    var provider = result.getString(&quot;ordering_provider&quot;);
    if (provider &amp;&amp; provider !== &apos;UNKNOWN&apos; &amp;&amp; provider !== &apos;&apos;) {
        observation.performer = [
            {
                &quot;display&quot;: provider
            }
        ];
    }

    observations.push(observation);
}
dbConn.close();

var bundle = {
    &quot;resourceType&quot;: &quot;Bundle&quot;,
    &quot;type&quot;: &quot;searchset&quot;,
    &quot;total&quot;: observations.length,
    &quot;entry&quot;: observations.map(function(obs) {
        return { &quot;resource&quot;: obs };
    })
};

var responseContent = JSON.stringify(bundle, null, 2);
responseMap.put(&apos;response&apos;, responseContent);
return responseContent;</script>
